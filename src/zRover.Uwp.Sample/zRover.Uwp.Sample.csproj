  <!--
    ── FullTrust companion: auto-build & include ────────────────────────

    We can't use <ProjectReference> across UWP → SDK-style .NET 8, so we
    shell out to 'dotnet build' automatically, then:
      * Copy output to AppX\FullTrust\ for VS F5 loose-layout debugging.
      * Inject into AppxPackagePayload for .msix packaging.
  -->
  <Target Name="_BuildFullTrustProject" BeforeTargets="PrepareForBuild"
          Condition="'$(BuildingInsideVisualStudio)' != 'true' and '$(BuildingSolutionFile)' != 'true' and ('$(SolutionDir)' == '' or '$(SolutionDir)' == '*Undefined*')">
    <Exec Command="dotnet build &quot;$(MSBuildThisFileDirectory)..\zRover.FullTrust.McpServer\zRover.FullTrust.McpServer.csproj&quot; -c $(Configuration) --no-self-contained" />
  </Target>

  <!-- Copy FullTrust output into the AppX loose layout so F5 debugging works. -->
  <Target Name="_CopyFullTrustToLayout"
          AfterTargets="Build"
          DependsOnTargets="_BuildFullTrustProject"
          Condition="Exists('$(OutDir)AppX\AppxManifest.xml')">
    <ItemGroup>
      <_FTLayoutFiles Include="$(FullTrustBuildDir)**\*"
                      Exclude="$(FullTrustBuildDir)**\*.pdb;$(FullTrustBuildDir)**\*.staticwebassets.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_FTLayoutFiles)"
          DestinationFiles="@(_FTLayoutFiles->'$(OutDir)AppX\FullTrust\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Inject FullTrust output into the .msix payload for packaged deployment. -->
  <Target Name="_AddFullTrustToPayload" BeforeTargets="_ComputeAppxPackagePayload">
    <ItemGroup>
      <_FullTrustFiles Include="$(FullTrustBuildDir)**\*"
                       Exclude="$(FullTrustBuildDir)**\*.pdb;$(FullTrustBuildDir)**\*.staticwebassets.*" />
      <AppxPackagePayload Include="@(_FullTrustFiles)">
        <TargetPath>FullTrust\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
      </AppxPackagePayload>
    </ItemGroup>
  </Target>

