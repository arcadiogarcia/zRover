  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />

  <!--
    Inject the complete FullTrust build output into AppxPackagePayload — the official
    UWP payload extensibility point — so that both VS Build and VS Deploy copy the files
    into AppX\FullTrust\ automatically.  The UWP build system only carries the .exe
    launcher; everything else (.dll entry-point, runtimeconfig, third-party assemblies)
    must be registered here so the appxrecipe covers them.
  -->
  <Target Name="_AddFullTrustToPayload" BeforeTargets="_ComputeAppxPackagePayload">
    <ItemGroup>
      <_FullTrustFiles Include="$(MSBuildThisFileDirectory)..\zRover.FullTrust.McpServer\bin\$(Configuration)\net8.0-windows10.0.19041.0\**\*" />
      <AppxPackagePayload Include="@(_FullTrustFiles)">
        <TargetPath>FullTrust\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
      </AppxPackagePayload>
    </ItemGroup>
  </Target>

