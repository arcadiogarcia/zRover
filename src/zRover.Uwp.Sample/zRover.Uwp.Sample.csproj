  <!-- Include the published FullTrust MCP server exe in the AppX package.
       The server is published as a self-contained single-file, so we only need one exe.
       Pick win-arm64 when building for ARM64 (or AnyCPU on ARM64 host), otherwise win-x64. -->
  <PropertyGroup>
    <!-- Derive RID from the build Platform, not the host OS architecture.
         On ARM64 hosts building x64 (emulation), Platform=x64 so we want win-x64. -->
    <_FullTrustRid Condition="'$(Platform)' == 'ARM64'">win-arm64</_FullTrustRid>
    <_FullTrustRid Condition="'$(Platform)' == 'x64'">win-x64</_FullTrustRid>
    <_FullTrustRid Condition="'$(Platform)' == 'x86'">win-x86</_FullTrustRid>
    <!-- Fallback for AnyCPU: use host architecture -->
    <_SampleHostArch Condition="'$(_FullTrustRid)' == ''">$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)</_SampleHostArch>
    <_FullTrustRid Condition="'$(_FullTrustRid)' == '' AND '$(_SampleHostArch)' == 'Arm64'">win-arm64</_FullTrustRid>
    <_FullTrustRid Condition="'$(_FullTrustRid)' == ''">win-x64</_FullTrustRid>
    <FullTrustPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\zRover.FullTrust.McpServer\bin\$(Configuration)\net8.0-windows10.0.19041.0\$(_FullTrustRid)\publish\'))</FullTrustPublishDir>
  </PropertyGroup>
  <ItemGroup Condition="Exists('$(FullTrustPublishDir)zRover.FullTrust.McpServer.exe')">
    <Content Include="$(FullTrustPublishDir)zRover.FullTrust.McpServer.exe">
      <Link>FullTrust\zRover.FullTrust.McpServer.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
