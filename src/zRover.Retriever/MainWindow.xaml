<Window
    x:Class="zRover.Retriever.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="zRover Retriever">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="zRover Retriever"
                           Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="AppVersionText"
                           Text=""
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Opacity="0.5"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,3"/>
            </StackPanel>
            <TextBlock x:Name="LocalDeviceInfoText"
                       Text=""
                       Opacity="0.6"
                       FontSize="12"/>
        </StackPanel>

        <!-- Two-column body -->
        <Grid Grid.Row="1" ColumnSpacing="32" Margin="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Status column -->
            <StackPanel Grid.Column="0" Spacing="20">

                <!-- Service Info -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Service" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Green" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Running" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ListeningUrlText" Text="URL: —" Opacity="0.7"/>
                </StackPanel>

                <!-- Controlled Remote Retrievers (outbound: this instance controls them) -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Controlled Remote Retrievers" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ListView x:Name="ManagersList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayText}"/>
                                        <TextBlock Text="{Binding DetailText}" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Disconnect" Tag="{Binding ManagerId}"
                                            Click="OnDisconnectManagerClicked" Padding="8,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="NoManagersText"
                               Text="No controlled remote retrievers"
                               Opacity="0.5" FontSize="12"/>
                </StackPanel>

                <!-- Controlling Remote Retrievers (inbound: they control this instance) -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Controlling Remote Retrievers" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ListView x:Name="ControllersList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="Green" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayText}"/>
                                        <TextBlock Text="{Binding DetailText}" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="NoControllersText"
                               Text="No remote retrievers controlling this instance"
                               Opacity="0.5" FontSize="12"/>
                </StackPanel>

                <!-- Past Remote Retrievers -->
                <StackPanel x:Name="PastManagersPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock Text="Past Remote Retrievers" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ListView x:Name="PastManagersList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="Gray" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayText}"
                                               VerticalAlignment="Center" Opacity="0.7"/>
                                    <Button Grid.Column="2" Content="Reconnect" Tag="{Binding}"
                                            Click="OnReconnectManagerClicked" Padding="8,2"/>
                                    <Button Grid.Column="3" Content="Forget" Tag="{Binding}"
                                            Click="OnForgetManagerClicked" Padding="8,2"
                                            Margin="4,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Sessions -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Connected Sessions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ListView x:Name="SessionsList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                             Fill="{Binding StatusColor}"
                                             VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Details}" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Active"
                                               Foreground="Green" FontWeight="SemiBold"
                                               Visibility="{Binding ActiveVisibility}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="NoSessionsText"
                               Text="No sessions connected"
                               Opacity="0.5" FontSize="12"/>
                </StackPanel>

            </StackPanel>

            <!-- RIGHT: Settings column -->
            <StackPanel Grid.Column="1" Spacing="20" Width="300">

                <!-- External Access -->
                <StackPanel Spacing="8">
                    <TextBlock Text="External Access" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="ExternalToggle"
                                  Header="Allow external connections"
                                  Toggled="OnExternalToggled"/>
                    <StackPanel x:Name="ExternalInfoPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock x:Name="ExternalUrlText" Opacity="0.7" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                        <Button x:Name="CopyLinkButton" Content="Copy connection link" Click="OnCopyLinkClicked"/>
                        <TextBlock x:Name="ExternalTokenText" Opacity="0.5" FontSize="11" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                        <Image x:Name="QrCodeImage"
                               Width="200" Height="200"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Left"
                               Stretch="Uniform"/>
                    </StackPanel>
                </StackPanel>

                <!-- Package Installation -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Package Installation" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="PackageInstallToggle"
                                  Header="Allow MCP clients to install/uninstall packages"
                                  Toggled="OnPackageInstallToggled"/>
                </StackPanel>

            </StackPanel>

        </Grid>
    </Grid>
</Window>
