<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10" xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10" xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities" xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10" IgnorableNamespaces="uap rescap desktop">
  <!--
    Identity: Name and Publisher are placeholders for sideloaded / dev builds.
    For Microsoft Store submissions Partner Center will assign the final
    Identity/@Name, Identity/@Publisher and Properties/PublisherDisplayName
    (or set them via /p:AppxPackageName=... at pack time). Do not commit
    Store-specific values here.
  -->
  <Identity Name="58996ARCADIOGARCA.zRoverRetriever" Publisher="CN=5F63796F-84F4-4C45-860F-616E76512FFB" ProcessorArchitecture="arm64" Version="1.0.0.1" />
  <Properties>
    <DisplayName>zRover Retriever</DisplayName>
    <PublisherDisplayName>ARCADIO GARCÍA</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>
  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
    <PackageDependency Name="Microsoft.WindowsAppRuntime.1.8" MinVersion="8000.317.322.0" Publisher="CN=Microsoft Corporation, O=Microsoft Corporation, L=Redmond, S=Washington, C=US" />
  </Dependencies>
  <Resources>
    <Resource Language="en-us" />
  </Resources>
  <Applications>
    <Application Id="App" Executable="zRover.Retriever.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="zRover Retriever" Description="zRover Retriever — MCP Server" Square150x150Logo="Assets\Square150x150Logo.png" Square44x44Logo="Assets\Square44x44Logo.png" BackgroundColor="#1F1F1F">
        <uap:DefaultTile Square71x71Logo="Assets\SmallTile.png" Wide310x150Logo="Assets\WideTile.png" Square310x310Logo="Assets\LargeTile.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1F1F1F" />
      </uap:VisualElements>
      <Extensions>
        <!--
          StartupTask: registered but disabled by default.
          The user opts in from the Retriever's settings UI (or from the
          Windows Settings > Apps > Startup page). This complies with
          Microsoft Store policy 10.2.1, which restricts apps from auto-
          starting on first install without consent.
        -->
        <desktop:Extension Category="windows.startupTask" Executable="zRover.Retriever.exe" EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="zRoverRetrieverStartup" Enabled="false" DisplayName="zRover Retriever" />
        </desktop:Extension>
        <!-- Protocol activation: zrover:// URI scheme for remote pairing -->
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="zrover">
            <uap:DisplayName>zRover Remote Control</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>
  <Capabilities>
    <!-- Required to act as the local MCP HTTP server and to broker external pairing. -->
    <Capability Name="internetClient" />
    <Capability Name="internetClientServer" />
    <Capability Name="privateNetworkClientServer" />
    <!-- runFullTrust is required for all packaged Win32/desktop apps. -->
    <rescap:Capability Name="runFullTrust" />
    <!--
      Restricted capabilities below require Microsoft Store justification.
      Justifications (mirror in Partner Center submission notes):
        appDiagnostics    — used to enumerate and gracefully terminate
                            packaged app instances via AppDiagnosticInfo for
                            the MCP `stop_app` tool. Falls back to a Win32
                            process scan if the capability is denied.
        packageManagement — only used by the optional install/uninstall MCP
                            tools when the user has explicitly enabled the
                            "Allow MCP clients to install/uninstall packages"
                            toggle in the Retriever UI. Per-user install
                            works without this capability; it is required
                            only for installForAllUsers / removeForAllUsers.
    -->
    <rescap:Capability Name="appDiagnostics" />
    <rescap:Capability Name="packageManagement" />
  </Capabilities>
</Package>