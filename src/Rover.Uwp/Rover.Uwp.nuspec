<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Rover.Uwp</id>
    <version>0.3.0-preview</version>
    <title>Rover - MCP Tools for UWP Apps</title>
    <authors>Rover Contributors</authors>
    <description>Add Model Context Protocol (MCP) tool endpoints to any UWP app. Rover exposes input injection, screenshot capture, and coordinate validation tools through a FullTrust companion MCP server, letting AI agents interact with your app's UI.

Minimal integration: three lines in App.xaml.cs.</description>
    <readme>docs\README.md</readme>
    <projectUrl>https://github.com/ArcadioG/Rover</projectUrl>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>uwp mcp ai tools input-injection screenshot model-context-protocol</tags>
    <dependencies>
      <group targetFramework="UAP10.0">
        <dependency id="Microsoft.NETCore.UniversalWindowsPlatform" version="6.2.14" />
        <dependency id="Newtonsoft.Json" version="13.0.3" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- UWP library -->
    <file src="bin\Release\Rover.Uwp.dll" target="lib\uap10.0\" />
    <file src="bin\Release\Rover.Uwp.pdb" target="lib\uap10.0\" />
    <!-- MSBuild auto-import targets -->
    <file src="build\uap10.0\Rover.Uwp.targets" target="build\uap10.0\" />
    <!-- FullTrust companion server: win-x64 -->
    <file src="..\Rover.FullTrust.McpServer\bin\publish-fdd-x64\**\*" target="tools\fulltrust\win-x64\" />
    <!-- FullTrust companion server: win-arm64 -->
    <file src="..\Rover.FullTrust.McpServer\bin\publish-fdd-arm64\**\*" target="tools\fulltrust\win-arm64\" />
    <!-- Package README -->
    <file src="..\..\README.md" target="docs\" />
  </files>
</package>