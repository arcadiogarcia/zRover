<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>zRover.Uwp</id>
    <version>0.8.3-preview</version>
    <title>zRover - MCP Tools for UWP Apps</title>
    <authors>zRover Contributors</authors>
    <description>Add Model Context Protocol (MCP) tool endpoints to any UWP app. zRover exposes input injection, screenshot capture, coordinate validation, and app-defined action dispatch tools through a FullTrust companion MCP server, letting AI agents interact with your app's UI.

New in 0.8.0: Low-level pointer tools — pointer_down, pointer_move, pointer_up — for stateful multi-finger touch and pen gestures spanning multiple MCP calls. Supports mixed touch+pen sessions.

New in 0.5.0: App Action API — implement IActionableApp to expose your own app's operations as list_actions / dispatch_action MCP tools.

Minimal integration: three lines in App.xaml.cs.</description>
    <readme>docs\README.md</readme>
    <projectUrl>https://github.com/ArcadioG/zRover</projectUrl>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>uwp mcp ai tools input-injection screenshot model-context-protocol</tags>
    <dependencies>
      <group targetFramework="UAP10.0">
        <dependency id="Microsoft.NETCore.UniversalWindowsPlatform" version="6.2.14" />
        <dependency id="Newtonsoft.Json" version="13.0.3" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- UWP library -->
    <file src="bin\Release\zRover.Uwp.dll" target="lib\uap10.0\" />
    <file src="bin\Release\zRover.Uwp.pdb" target="lib\uap10.0\" />
    <!-- MSBuild auto-import targets -->
    <file src="build\uap10.0\zRover.Uwp.targets" target="build\uap10.0\" />
    <!-- FullTrust companion server: win-x64 -->
    <file src="..\zRover.FullTrust.McpServer\bin\publish-sc-x64\**\*" target="tools\fulltrust\win-x64\" />
    <!-- FullTrust companion server: win-arm64 -->
    <file src="..\zRover.FullTrust.McpServer\bin\publish-sc-arm64\**\*" target="tools\fulltrust\win-arm64\" />
    <!-- Package README -->
    <file src="..\..\README.md" target="docs\" />
  </files>
</package>